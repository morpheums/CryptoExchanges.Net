+        {
+            var httpClient = sp.GetRequiredService<IHttpClientFactory>().CreateClient(clientName);
+            var holder = sp.GetRequiredKeyedService<long[]>(exchangeId);
+            return exchangeClientFactory(sp, httpClient, holder);
+        });
+
+        return services;
+    }
+}
