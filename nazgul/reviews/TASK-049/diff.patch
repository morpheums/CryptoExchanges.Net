+        /// <inheritdoc/>
+        public HeartbeatPolicy Heartbeat { get; } = new HeartbeatPolicy(
+            Direction: HeartbeatDirection.ServerPingClientPong,
+            Interval: TimeSpan.FromSeconds(30),
