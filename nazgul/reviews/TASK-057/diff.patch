+    [Fact]
+    public void ErrorTranslator_SuccessEnvelope_IsNotATypedError()
+    {
+        // code == "200000" (a STRING) is a success envelope: must NOT become a typed subtype.
+        var ex = Translate(HttpStatusCode.OK, "{\"code\":\"200000\",\"msg\":\"\"}");
