+
+        var options = new StreamEngineOptions
+        {
+            IdleCloseDelay = TimeSpan.FromSeconds(5),
+            BackoffInitial = TimeSpan.FromMilliseconds(20),
+            BackoffMax = TimeSpan.FromMilliseconds(50),
+        };
