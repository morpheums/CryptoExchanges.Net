diff --git a/tests/CryptoExchanges.Net.Okx.Tests.Unit/OkxMappingAndServiceTests.cs b/tests/CryptoExchanges.Net.Okx.Tests.Unit/OkxMappingAndServiceTests.cs
new file mode 100644
