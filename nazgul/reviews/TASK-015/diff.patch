+        var ex = new OkxErrorTranslator().Translate(resp, "{\"code\":\"50011\",\"msg\":\"too many\"}");
+        ex.Should().BeOfType<RateLimitExceededException>();
+        ((RateLimitExceededException)ex).RetryAfter.Should().Be(TimeSpan.FromSeconds(7));
