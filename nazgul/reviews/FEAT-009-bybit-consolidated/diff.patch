diff --git a/tests/CryptoExchanges.Net.Bybit.Tests.Integration/Streaming/BybitStreamingSmokeTests.cs b/tests/CryptoExchanges.Net.Bybit.Tests.Integration/Streaming/BybitStreamingSmokeTests.cs
